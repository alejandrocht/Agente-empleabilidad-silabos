# ============================================================
# Agente CIAR v2 — copia este archivo a .env y completa secretos
# ============================================================

# OpenAI es el único proveedor. Cada rol puede usar un modelo distinto.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_ENTIDAD=gpt-4o-mini
OPENAI_MODEL_CYPHER=gpt-4o-mini
OPENAI_MODEL_ANALISIS=gpt-4o-mini
OPENAI_MODEL_RESUMEN=gpt-4o-mini
OPENAI_MODEL_INSPECTOR=gpt-4o-mini
LLM_TEMPERATURE=0

# Neo4j: todas las sesiones se abren explícitamente en modo READ_ACCESS.
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# Memoria y caché efímeras en RAM.
MEMORIA_TTL_SEGUNDOS=1800
MEMORIA_BLOQUE_CADA=12
CACHE_TTL_SEGUNDOS=600
CACHE_MAX_ENTRADAS=500

# Inspector remoto opcional; el inspector determinista siempre está activo.
INSPECTOR_LLM=false

# LangSmith observa automáticamente todas las llamadas realizadas por ChatOpenAI.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ciar-agente-v2
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
