# --- NVIDIA NIM (capa de inferencia, API compatible con OpenAI) ---
# Consigue la key gratis en https://build.nvidia.com (Get API Key).
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Modelo del catalogo NVIDIA. Default: meta/llama-3.3-70b-instruct.
# Alternativas: qwen/qwen2.5-coder-32b-instruct (mejor Cypher),
#               nvidia/llama-3.3-nemotron-super-49b-v1 (razonamiento).
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TEMPERATURE=0

# --- Neo4j ---
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# --- LangSmith (observabilidad; opcional, traza solo si hay API key) ---
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_xxx
LANGSMITH_PROJECT=ciar-local-langgraph
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- LangGraph ---
LANGGRAPH_RECURSION_LIMIT=8
