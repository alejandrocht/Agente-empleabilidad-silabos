# ============================================================
#  Configuracion del agente CIAR (copia este archivo a .env)
# ============================================================

# --- LLM (modelo de IA) configurable -------------------------
# Proveedor del modelo. Por defecto Google Gemini.
# Otros: groq, openai, together, etc. (instala el paquete del proveedor que uses).
LLM_PROVIDER=google_genai
# Modelo concreto dentro del proveedor.
LLM_MODEL=gemini-2.0-flash
# Creatividad. 0 = preciso y estable (recomendado para generar Cypher).
LLM_TEMPERATURE=0

# API key del proveedor elegido. Para Gemini:
#   consiguela en https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=tu_api_key_de_google_aqui
# Si usas otro proveedor, define su key en su lugar, por ejemplo:
# GROQ_API_KEY=gsk_xxx
# OPENAI_API_KEY=sk-xxx
# TOGETHER_API_KEY=xxx

# --- Neo4j ---------------------------------------------------
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# --- LangSmith (observabilidad; opcional) --------------------
# Si quieres grabar las trazas, pon tu key. Si no, dejalo vacio.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ciar-local-langgraph
