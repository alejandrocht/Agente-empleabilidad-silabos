# ============================================================
#  Configuracion del agente CIAR (copia este archivo a .env)
# ============================================================

# --- LLM (modelo de IA) configurable -------------------------
# Proveedor PRINCIPAL (se intenta primero).
# Opciones: openai, google_genai, nvidia, ollama (instala el paquete que uses).
LLM_PROVIDER=openai
# Modelo del proveedor principal.
LLM_MODEL=gpt-4o-mini
# PUENTE / fallback (opcional): proveedor(es) de respaldo separados por comas.
# Si el principal falla en ejecucion (ej. OpenAI 429 sin cuota), usa el siguiente.
# Ejemplo "Gemini ahora, OpenAI cuando tenga saldo": LLM_PROVIDER=openai + LLM_FALLBACK=google_genai
LLM_FALLBACK=google_genai
# Creatividad. 0 = preciso y estable (recomendado para generar Cypher).
LLM_TEMPERATURE=0

# API keys. Define la del proveedor principal Y la de cada respaldo que uses.
#   OpenAI: https://platform.openai.com/api-keys
#   Gemini: https://aistudio.google.com/app/apikey
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Otros proveedores, si los usas:
# GROQ_API_KEY=gsk_xxx
# TOGETHER_API_KEY=xxx

# --- Neo4j ---------------------------------------------------
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- LangSmith (observabilidad; opcional) --------------------
# Si quieres grabar las trazas, pon tu key. Si no, dejalo vacio.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agente_empleabilidad
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

