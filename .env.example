# ============================================================
#  Configuracion del agente CIAR (copia este archivo a .env)
# ============================================================

# --- LLM (modelo de IA) configurable -------------------------
# Proveedor activo: nvidia | ollama | google_genai
# Cambia solo esta linea para testear con otro modelo, sin tocar codigo.
LLM_PROVIDER=nvidia
# Temperatura por defecto si el proveedor no define la suya propia.
# 0 = preciso y estable (recomendado para generar Cypher).
LLM_TEMPERATURE=0

# --- NVIDIA NIM (capa de inferencia, API compatible con OpenAI) ---
# Key gratis en https://build.nvidia.com (Get API Key).
NVIDIA_API_KEY=tu_api_key_de_nvidia_aqui
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_TEMPERATURE=0

# --- Ollama (modelo local, requiere "ollama serve" corriendo) ---
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEMPERATURE=0

# --- Google Gemini ---
# Key en https://aistudio.google.com/app/apikey
LLM_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=tu_api_key_de_google_aqui

# --- Neo4j ---------------------------------------------------
NEO4J_URI=neo4j://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# --- LangSmith (observabilidad; opcional) --------------------
# Si quieres grabar las trazas, pon tu key. Si no, dejalo vacio.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ciar-local-langgraph
